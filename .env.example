# Slack Socket Mode — never commit real xapp-/xoxb- values
SLACK_APP_TOKEN=replace-with-app-level-token
SLACK_BOT_TOKEN=replace-with-bot-token

# Free model providers
GEMINI_API_KEY=your-free-gemini-api-key
GROQ_API_KEY=your-free-groq-api-key
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_API_KEY=ollama
OPENCLAW_MODEL=ollama/qwen2.5-coder
HERMES_MODEL=gemini-2.5-flash

# Slack channel IDs for round-trip verification
SLACK_SPRINT_MAIN_CHANNEL_ID=C0XXXXXXXXX
SLACK_AGENT_CODER_CHANNEL_ID=C0XXXXXXXXX
SLACK_AGENT_LOG_CHANNEL_ID=C0XXXXXXXXX
